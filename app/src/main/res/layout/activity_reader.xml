<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- 阅读器视图（全屏） -->
    <com.einkreader.ui.reader.ReaderView
        android:id="@+id/reader_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="0dp" />

    <!-- 全屏加载覆盖层（白底大字，墨水屏可见） -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@android:color/white"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在加载"
            android:textColor="@android:color/black"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/loading_filename"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text=""
            android:textColor="@android:color/black"
            android:textSize="20sp"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="end" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="请稍候..."
            android:textColor="@android:color/black"
            android:textSize="24sp" />
    </LinearLayout>

    <!-- 顶部状态栏（白底黑字，简洁分格） -->
    <LinearLayout
        android:id="@+id/top_status_bar"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@android:color/white"
        android:paddingLeft="0dp"
        android:paddingRight="0dp"
        android:visibility="gone">

        <!-- 时间 -->
        <TextView
            android:id="@+id/status_time"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@android:color/black"
            android:textSize="13sp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="@android:color/black" />

        <!-- 章节名 -->
        <TextView
            android:id="@+id/status_chapter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:gravity="center"
            android:textColor="@android:color/black"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:paddingLeft="6dp"
            android:paddingRight="6dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="@android:color/black" />

        <!-- 电量 -->
        <TextView
            android:id="@+id/status_battery"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@android:color/black"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 底部菜单栏（纯文字白底分格，无图标，两排） -->
    <LinearLayout
        android:id="@+id/bottom_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:visibility="gone">

        <!-- 第一行：导航和设置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="返回"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
            <View android:layout_width="1dp" android:layout_height="32dp" android:background="@android:color/black" />

            <TextView
                android:id="@+id/btn_toc"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="目录"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
            <View android:layout_width="1dp" android:layout_height="32dp" android:background="@android:color/black" />

            <TextView
                android:id="@+id/btn_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="设置"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
            <View android:layout_width="1dp" android:layout_height="32dp" android:background="@android:color/black" />

            <TextView
                android:id="@+id/btn_show_log"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="日志"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@android:color/black" />

        <!-- 第二行：字号和亮度 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btn_font_minus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="字小"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
            <View android:layout_width="1dp" android:layout_height="32dp" android:background="@android:color/black" />

            <TextView
                android:id="@+id/btn_font_plus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="字大"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
            <View android:layout_width="1dp" android:layout_height="32dp" android:background="@android:color/black" />

            <TextView
                android:id="@+id/btn_bright_minus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="亮-"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
            <View android:layout_width="1dp" android:layout_height="32dp" android:background="@android:color/black" />

            <TextView
                android:id="@+id/btn_bright_plus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="亮+"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
            <View android:layout_width="1dp" android:layout_height="32dp" android:background="@android:color/black" />

            <TextView
                android:id="@+id/btn_full_refresh"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="全刷"
                android:textColor="@android:color/black"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
