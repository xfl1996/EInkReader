<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:name=".EInkReaderApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme"
        android:hardwareAccelerated="false">

        <activity
            android:name=".ui.library.LibraryActivity"
            android:label="@string/app_name"
            android:exported="true">
            <!-- 普通启动入口 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 打开 TXT/EPUB 文件 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="application/epub+zip" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.reader.ReaderActivity"
            android:label="@string/reader"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:label="@string/settings" />

        <activity
            android:name=".ui.reader.TocActivity"
            android:label="目录"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.library.RefreshSettingsActivity"
            android:label="刷新设置"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.reader.ReadingSettingsActivity"
            android:label="阅读设置"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.library.FilePickerActivity"
            android:label="选择文件"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.reader.QrLogActivity"
            android:label="日志二维码"
            android:screenOrientation="portrait"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

    </application>

</manifest>
